---
import Layout from '../layouts/Layout.astro';
import Hero from '../components/Hero.astro';
import SectionTitle from '../components/SectionTitle.astro';
---

<Layout title="Inicio" description="Centro de Fisioterapia y Pilates Atlas en Carabanchel Alto, Madrid. Masajes, rehabilitación y clases de Pilates con fisioterapeutas expertos. Llámanos: 691 487 526.">
  <!-- Hero -->
  <Hero
    title="Tu salud, en buenas manos"
    subtitle="Centro especializado en Fisioterapia, masajes y rehabilitación en Carabanchel Alto. Tratamos tus lesiones y mejoramos tu bienestar con atención personalizada."
    ctaText="Pedir cita"
    ctaHref="/contacto"
    ctaSecondaryText="Ver servicios"
    ctaSecondaryHref="/fisioterapia"
    backgroundImage="/images/DSC_0040.jpg"
  />

  <!-- Qué hacemos -->
  <section class="py-12 sm:py-16 md:py-20 bg-bg-light">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <SectionTitle
        title="¿Qué ofrecemos?"
        subtitle="En Fisiopilates Atlas combinamos fisioterapia avanzada y Pilates para cuidar tu salud de forma integral."
      />
      <div class="grid grid-cols-1 sm:grid-cols-2 md:grid-cols-3 gap-4 sm:gap-6 md:gap-8">
        <!-- Fisioterapia -->
        <a href="/fisioterapia" class="group bg-white rounded-2xl p-5 sm:p-6 md:p-8 shadow-card border border-border text-center hover:shadow-card-hover hover:-translate-y-1 transition-all duration-300">
          <div class="w-14 h-14 sm:w-16 sm:h-16 bg-primary/10 rounded-2xl flex items-center justify-center mx-auto mb-4 sm:mb-6 group-hover:bg-primary/15 transition-colors">
            <svg class="w-7 h-7 sm:w-8 sm:h-8 text-primary" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4.318 6.318a4.5 4.5 0 000 6.364L12 20.364l7.682-7.682a4.5 4.5 0 00-6.364-6.364L12 7.636l-1.318-1.318a4.5 4.5 0 00-6.364 0z" />
            </svg>
          </div>
          <h3 class="text-lg sm:text-xl font-bold mb-2 sm:mb-3 text-text-dark">Fisioterapia</h3>
          <p class="text-text-gray text-sm leading-relaxed">
            Masajes, rehabilitación y tratamiento de lesiones musculoesqueléticas. Sesiones personalizadas de aproximadamente una hora.
          </p>
          <span class="mt-4 inline-flex items-center gap-1 text-primary text-sm font-semibold group-hover:gap-2 transition-all">
            Saber más
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3" />
            </svg>
          </span>
        </a>

        <!-- Pilates -->
        <a href="/pilates" class="group bg-white rounded-2xl p-5 sm:p-6 md:p-8 shadow-card border border-border text-center hover:shadow-card-hover hover:-translate-y-1 transition-all duration-300">
          <div class="w-14 h-14 sm:w-16 sm:h-16 bg-accent/10 rounded-2xl flex items-center justify-center mx-auto mb-4 sm:mb-6 group-hover:bg-accent/15 transition-colors">
            <svg class="w-7 h-7 sm:w-8 sm:h-8 text-accent" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z" />
            </svg>
          </div>
          <h3 class="text-lg sm:text-xl font-bold mb-2 sm:mb-3 text-text-dark">Pilates</h3>
          <p class="text-text-gray text-sm leading-relaxed">
            Clases en grupos reducidos (máx. 5 personas) impartidas por fisioterapeutas expertos. También Pilates para embarazadas.
          </p>
          <span class="mt-4 inline-flex items-center gap-1 text-accent text-sm font-semibold group-hover:gap-2 transition-all">
            Saber más
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3" />
            </svg>
          </span>
        </a>

        <!-- Atención personalizada -->
        <div class="bg-white rounded-2xl p-5 sm:p-6 md:p-8 shadow-card border border-border text-center sm:col-span-2 md:col-span-1">
          <div class="w-14 h-14 sm:w-16 sm:h-16 bg-warm/10 rounded-2xl flex items-center justify-center mx-auto mb-4 sm:mb-6">
            <svg class="w-7 h-7 sm:w-8 sm:h-8 text-warm" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z" />
            </svg>
          </div>
          <h3 class="text-lg sm:text-xl font-bold mb-2 sm:mb-3 text-text-dark">Atención personalizada</h3>
          <p class="text-text-gray text-sm leading-relaxed">
            Colaboramos con mutuas y seguros médicos. Instalaciones adaptadas y protocolos de higiene y prevención.
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- Por qué elegirnos -->
  <section class="py-12 sm:py-16 md:py-20">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <SectionTitle
        title="¿Por qué elegirnos?"
        subtitle="Un equipo de fisioterapeutas expertos a tu servicio en el corazón de Carabanchel Alto."
      />
      <div class="grid grid-cols-1 sm:grid-cols-2 gap-4 sm:gap-6">
        {[
          {
            icon: 'M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2',
            title: 'Fisioterapeutas especializados',
            desc: 'Todo el equipo son fisioterapeutas titulados con amplia experiencia en rehabilitación y Pilates terapéutico.'
          },
          {
            icon: 'M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0z',
            title: 'Grupos reducidos',
            desc: 'Las clases de Pilates se imparten en grupos de máximo 5 personas para garantizar la atención individualizada.'
          },
          {
            icon: 'M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5M9 7h1m-1 4h1m4-4h1m-1 4h1m-5 10v-5a1 1 0 011-1h2a1 1 0 011 1v5m-4 0h4',
            title: 'Instalaciones equipadas',
            desc: 'Centro completamente equipado y adaptado, con medidas de higiene y prevención para garantizar tu seguridad.'
          },
          {
            icon: 'M3 10h18M7 15h1m4 0h1m-7 4h12a3 3 0 003-3V8a3 3 0 00-3-3H6a3 3 0 00-3 3v8a3 3 0 003 3z',
            title: 'Colaboramos con mutuas',
            desc: 'Trabajamos con diversas compañías de seguros y mutuas para facilitar el acceso a nuestros tratamientos.'
          },
        ].map(item => (
          <div class="flex gap-4 p-5 sm:p-6 bg-bg-light rounded-2xl border border-border">
            <div class="w-11 h-11 bg-primary/10 rounded-xl flex items-center justify-center shrink-0">
              <svg class="w-5 h-5 text-primary" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d={item.icon} />
              </svg>
            </div>
            <div>
              <h3 class="font-bold text-text-dark mb-1">{item.title}</h3>
              <p class="text-text-gray text-sm leading-relaxed">{item.desc}</p>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Cómo llegar -->
  <section class="py-12 sm:py-16 md:py-20 bg-bg-light">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <SectionTitle
        title="Cómo llegar"
        subtitle="Estamos en Carabanchel Alto, bien comunicados con transporte público."
      />
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-8 items-center">
        <div class="space-y-4">
          <div class="flex items-start gap-3 p-4 bg-white rounded-xl border border-border">
            <svg class="w-5 h-5 text-primary mt-0.5 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z" />
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z" />
            </svg>
            <div>
              <p class="font-semibold text-text-dark">Dirección</p>
              <p class="text-text-gray text-sm">c/Travesía de Alfredo Aleix, 1 (local)<br/>Junto al banco La Caixa · Carabanchel Alto, 28044 Madrid</p>
            </div>
          </div>
          <div class="flex items-start gap-3 p-4 bg-white rounded-xl border border-border">
            <svg class="w-5 h-5 text-primary mt-0.5 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z" />
            </svg>
            <div>
              <p class="font-semibold text-text-dark">Horario</p>
              <p class="text-text-gray text-sm">Lunes a Viernes: 10:00 – 21:00 h</p>
            </div>
          </div>
          <div class="flex items-start gap-3 p-4 bg-white rounded-xl border border-border">
            <svg class="w-5 h-5 text-primary mt-0.5 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7h12m0 0l-4-4m4 4l-4 4m0 6H4m0 0l4 4m-4-4l4-4" />
            </svg>
            <div>
              <p class="font-semibold text-text-dark">Transporte público</p>
              <p class="text-text-gray text-sm">
                Metro: <strong>La Peseta</strong> · <strong>Carabanchel Alto</strong><br/>
                Autobús: <strong>35</strong> · <strong>47</strong>
              </p>
            </div>
          </div>
        </div>
        <!-- Map placeholder -->
        <div class="bg-white rounded-2xl border border-border overflow-hidden h-72 sm:h-80 lg:h-96">
          <iframe
            src="https://maps.google.com/maps?q=Fisiopilates+Atlas+Carabanchel+Alto+Madrid&output=embed&hl=es&z=17"
            width="100%"
            height="100%"
            style="border:0;"
            allowfullscreen
            loading="lazy"
            referrerpolicy="no-referrer-when-downgrade"
            title="Ubicación Fisiopilates Atlas"
          ></iframe>
        </div>
      </div>
    </div>
  </section>

  <!-- Galería del centro -->
  <section class="py-12 sm:py-16 md:py-20">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <SectionTitle
        title="Nuestro centro"
        subtitle="Instalaciones modernas y adaptadas en el corazón de Carabanchel Alto."
        centered
      />
      <div class="grid grid-cols-1 sm:grid-cols-2 gap-3 sm:gap-4">
        <img src="/images/DSC_0009.jpg" alt="Sala de fisioterapia — Fisiopilates Atlas" class="w-full h-56 sm:h-80 object-cover rounded-xl" loading="lazy" />
        <img src="/images/DSC_0020.jpg" alt="Sala de Pilates — Fisiopilates Atlas" class="w-full h-56 sm:h-80 object-cover rounded-xl" loading="lazy" />
      </div>
    </div>
  </section>

  <!-- CTA Final -->
  <section class="py-12 sm:py-16 md:py-20 bg-primary text-white text-center">
    <div class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8">
      <h2 class="text-2xl sm:text-3xl md:text-4xl font-extrabold mb-4 sm:mb-6">
        ¿Listo para empezar?
      </h2>
      <p class="text-teal-100 text-base sm:text-lg mb-6 sm:mb-8 leading-relaxed">
        Pide tu cita ahora y empieza a cuidar tu salud con nuestro equipo de fisioterapeutas especializados.
      </p>
      <div class="flex flex-wrap justify-center gap-4">
        <a
          href="/contacto"
          class="inline-flex items-center gap-2 bg-white text-primary px-6 py-3 sm:px-8 sm:py-4 rounded-xl font-semibold text-base sm:text-lg hover:bg-teal-50 transition-all duration-300 shadow-lg hover:shadow-xl"
        >
          Pedir cita
          <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />
          </svg>
        </a>
        <a
          href="tel:691487526"
          class="inline-flex items-center gap-2 bg-white/15 text-white border border-white/30 px-6 py-3 sm:px-8 sm:py-4 rounded-xl font-semibold text-base sm:text-lg hover:bg-white/25 transition-all duration-300"
        >
          <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" />
          </svg>
          691 487 526
        </a>
      </div>
    </div>
  </section>
</Layout>
