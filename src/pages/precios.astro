---
import Layout from '../layouts/Layout.astro';
import Hero from '../components/Hero.astro';
import SectionTitle from '../components/SectionTitle.astro';
---

<Layout
  title="Precios y tarifas"
  description="Tarifas de fisioterapia y Pilates en Fisiopilates Atlas, Carabanchel Alto Madrid. Consulta nuestros precios actualizados para masajes, rehabilitación y clases de Pilates."
>
  <Hero
    title="Precios y tarifas"
    subtitle="Consulta nuestras tarifas actualizadas para fisioterapia y clases de Pilates. Sin sorpresas."
    backgroundImage="/images/pilates_clase.webp"
    compact
  />

  <section class="py-12 sm:py-16 md:py-20">
    <div class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8">

      <!-- Aviso actualización -->
      <div class="bg-warm/10 border border-warm/20 rounded-2xl p-4 sm:p-5 mb-10 flex items-start gap-3">
        <svg class="w-5 h-5 text-warm mt-0.5 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
        </svg>
        <p class="text-sm text-text-gray">
          Tarifas actualizadas. Para información sobre seguros médicos y mutuas, <a href="/contacto" class="text-primary font-semibold hover:underline">contáctanos directamente</a>.
        </p>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-2 gap-8">

        <!-- Fisioterapia -->
        <div>
          <div class="flex items-center gap-3 mb-6">
            <div class="w-10 h-10 bg-primary/10 rounded-xl flex items-center justify-center">
              <svg class="w-5 h-5 text-primary" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4.318 6.318a4.5 4.5 0 000 6.364L12 20.364l7.682-7.682a4.5 4.5 0 00-6.364-6.364L12 7.636l-1.318-1.318a4.5 4.5 0 00-6.364 0z" />
              </svg>
            </div>
            <h2 class="text-xl font-extrabold text-text-dark">Fisioterapia</h2>
          </div>
          <div class="space-y-3">
            {[
              { servicio: 'Sesión individual (~1 hora)', precio: 'Consultar' },
              { servicio: 'Bono 5 sesiones', precio: 'Consultar' },
              { servicio: 'Bono 10 sesiones', precio: 'Consultar' },
              { servicio: 'Punción seca', precio: 'Consultar' },
              { servicio: 'Masaje deportivo', precio: 'Consultar' },
              { servicio: 'Masaje relajante', precio: 'Consultar' },
              { servicio: 'Tratamiento a domicilio', precio: 'Consultar' },
            ].map(item => (
              <div class="flex items-center justify-between p-4 bg-bg-light rounded-xl border border-border">
                <span class="text-sm text-text-dark font-medium">{item.servicio}</span>
                <span class="text-sm font-bold text-primary">{item.precio}</span>
              </div>
            ))}
          </div>
        </div>

        <!-- Pilates -->
        <div>
          <div class="flex items-center gap-3 mb-4">
            <div class="w-10 h-10 bg-accent/10 rounded-xl flex items-center justify-center">
              <svg class="w-5 h-5 text-accent" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z" />
              </svg>
            </div>
            <h2 class="text-xl font-extrabold text-text-dark">Pilates</h2>
          </div>
          <!-- Primera clase gratis -->
          <div class="flex items-center gap-2 bg-accent/10 border border-accent/20 rounded-xl px-4 py-2 mb-4">
            <svg class="w-4 h-4 text-accent shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v13m0-13V6a4 4 0 00-4-4H5.45a4 4 0 00-3.89 3.06L1 6m11 2h8.55a4 4 0 013.89 3.06L24 12v4a2 2 0 01-2 2H2a2 2 0 01-2-2v-4" />
            </svg>
            <span class="text-sm font-semibold text-accent">Primera clase GRATIS sin compromiso (con cita previa)</span>
          </div>
          <div class="space-y-3">
            {[
              { servicio: 'Grupos reducidos · 1 hora/semana', precio: '35 €/mes' },
              { servicio: 'Grupos reducidos · 2 horas/semana', precio: '60 €/mes' },
              { servicio: 'Sesión individual', precio: 'Consultar' },
              { servicio: 'Pilates para embarazadas', precio: 'Consultar' },
            ].map(item => (
              <div class="flex items-center justify-between p-4 bg-bg-light rounded-xl border border-border">
                <span class="text-sm text-text-dark font-medium">{item.servicio}</span>
                <span class="text-sm font-bold text-accent">{item.precio}</span>
              </div>
            ))}
          </div>
          <!-- Descuentos especiales -->
          <div class="mt-4 flex items-start gap-2 bg-primary/5 border border-primary/15 rounded-xl px-4 py-3">
            <svg class="w-4 h-4 text-primary mt-0.5 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M7 7h.01M7 3h5c.512 0 1.024.195 1.414.586l7 7a2 2 0 010 2.828l-7 7a2 2 0 01-2.828 0l-7-7A1.994 1.994 0 013 12V7a4 4 0 014-4z" />
            </svg>
            <p class="text-sm text-text-gray">
              <strong class="text-text-dark">Descuentos especiales</strong> con Carnet Joven o Carnet Tercera Edad. Consúltanos.
            </p>
          </div>
        </div>
      </div>

      <!-- Seguros y mutuas -->
      <div class="mt-12 bg-primary/5 border border-primary/15 rounded-2xl p-6 sm:p-8">
        <h3 class="text-lg font-bold text-text-dark mb-4 flex items-center gap-2">
          <svg class="w-5 h-5 text-primary" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 10h18M7 15h1m4 0h1m-7 4h12a3 3 0 003-3V8a3 3 0 00-3-3H6a3 3 0 00-3 3v8a3 3 0 003 3z" />
          </svg>
          Seguros médicos y mutuas
        </h3>
        <p class="text-text-gray text-sm leading-relaxed mb-5">
          Nuestro centro tiene concertada la asistencia y la colaboración con distintas compañías aseguradoras:
        </p>
        <div class="flex flex-wrap gap-3 mb-5">
          <div class="flex items-center gap-2 bg-white border border-border rounded-xl px-4 py-2 text-sm font-semibold text-text-dark shadow-card">
            <svg class="w-4 h-4 text-primary" fill="currentColor" viewBox="0 0 24 24"><path d="M12 2L2 7v10l10 5 10-5V7L12 2z"/></svg>
            Mapfre Familiar
          </div>
          <div class="flex items-center gap-2 bg-white border border-border rounded-xl px-4 py-2 text-sm font-semibold text-text-dark shadow-card">
            <svg class="w-4 h-4 text-accent" fill="currentColor" viewBox="0 0 24 24"><path d="M12 2L2 7v10l10 5 10-5V7L12 2z"/></svg>
            Asefa Salud
          </div>
        </div>
        <p class="text-text-gray text-xs italic">En breve, incorporaremos nuevas compañías. Si tienes otra aseguradora, consúltanos.</p>
      </div>

      <!-- CTA contacto -->
      <div class="mt-10 text-center">
        <p class="text-text-gray mb-4">¿Necesitas más información sobre nuestras tarifas?</p>
        <div class="flex flex-wrap justify-center gap-4">
          <a href="/contacto" class="inline-flex items-center gap-2 bg-primary text-white px-6 py-3 rounded-xl font-semibold hover:bg-primary-light transition-all duration-300 shadow-card">
            Contáctanos
          </a>
          <a href="tel:691487526" class="inline-flex items-center gap-2 border border-border text-text-dark px-6 py-3 rounded-xl font-semibold hover:bg-bg-light transition-all duration-300">
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" />
            </svg>
            691 487 526
          </a>
        </div>
      </div>
    </div>
  </section>
</Layout>
