---
import Layout from '../layouts/Layout.astro';
import Hero from '../components/Hero.astro';
---

<Layout title="Contacto" description="Contacta con Fisiopilates Atlas. Pide tu cita de fisioterapia o infórmate sobre las clases de Pilates en Carabanchel Alto, Madrid.">
  <Hero
    title="Contacto"
    subtitle="Estaremos encantados de atenderte. Pide tu cita o consúltanos cualquier duda."
    compact
  />

  <section class="py-12 sm:py-16 md:py-20">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-10 lg:gap-16">

        <!-- Formulario -->
        <div>
          <!-- Mensajes de estado -->
          <div id="form-success" class="hidden mb-6 bg-green-50 border border-green-200 rounded-2xl p-4 sm:p-6 text-green-700">
            <p class="font-semibold">Mensaje enviado correctamente.</p>
            <p class="text-sm mt-1">Nos pondremos en contacto contigo a la mayor brevedad.</p>
          </div>
          <div id="form-error" class="hidden mb-6 bg-red-50 border border-red-200 rounded-2xl p-4 sm:p-6 text-red-700">
            <p class="font-semibold">Error al enviar el mensaje.</p>
            <p class="text-sm mt-1">Por favor, inténtalo de nuevo o llámanos directamente.</p>
          </div>
          <div id="form-captcha" class="hidden mb-6 bg-yellow-50 border border-yellow-200 rounded-2xl p-4 sm:p-6 text-yellow-700">
            <p class="font-semibold">Verificación de seguridad requerida.</p>
            <p class="text-sm mt-1">Por favor, completa el captcha antes de enviar el formulario.</p>
          </div>

          <div class="bg-white rounded-2xl shadow-card border border-border p-5 sm:p-8 md:p-10">
            <h2 class="text-xl sm:text-2xl font-bold text-text-dark mb-2">Escríbenos</h2>
            <p class="text-text-gray mb-8 text-sm">Rellena el formulario y te responderemos a la mayor brevedad.</p>

            <form action="/api/contacto.php" method="POST" class="space-y-5" id="contact-form">
              <!-- Nombre -->
              <div>
                <label for="nombre" class="block text-sm font-semibold text-text-dark mb-2">Nombre *</label>
                <input
                  type="text"
                  id="nombre"
                  name="nombre"
                  required
                  class="w-full px-4 py-3 rounded-xl border border-border focus:border-primary focus:ring-2 focus:ring-primary/20 outline-none transition-all text-text-dark"
                  placeholder="Tu nombre completo"
                />
              </div>

              <!-- Teléfono -->
              <div>
                <label for="telefono" class="block text-sm font-semibold text-text-dark mb-2">Teléfono</label>
                <input
                  type="tel"
                  id="telefono"
                  name="telefono"
                  class="w-full px-4 py-3 rounded-xl border border-border focus:border-primary focus:ring-2 focus:ring-primary/20 outline-none transition-all text-text-dark"
                  placeholder="Tu número de teléfono"
                />
              </div>

              <!-- Email -->
              <div>
                <label for="email" class="block text-sm font-semibold text-text-dark mb-2">Email *</label>
                <input
                  type="email"
                  id="email"
                  name="email"
                  required
                  class="w-full px-4 py-3 rounded-xl border border-border focus:border-primary focus:ring-2 focus:ring-primary/20 outline-none transition-all text-text-dark"
                  placeholder="tu@email.com"
                />
              </div>

              <!-- Motivo -->
              <div>
                <label for="motivo" class="block text-sm font-semibold text-text-dark mb-2">Motivo de consulta *</label>
                <select
                  id="motivo"
                  name="motivo"
                  required
                  class="w-full px-4 py-3 rounded-xl border border-border focus:border-primary focus:ring-2 focus:ring-primary/20 outline-none transition-all text-text-dark bg-white"
                >
                  <option value="">Selecciona un motivo</option>
                  <option value="fisioterapia">Cita de fisioterapia</option>
                  <option value="pilates">Información sobre Pilates</option>
                  <option value="precios">Consulta de precios</option>
                  <option value="seguros">Información sobre seguros / mutuas</option>
                  <option value="otro">Otro motivo</option>
                </select>
              </div>

              <!-- Mensaje -->
              <div>
                <label for="mensaje" class="block text-sm font-semibold text-text-dark mb-2">Mensaje *</label>
                <textarea
                  id="mensaje"
                  name="mensaje"
                  required
                  rows="4"
                  class="w-full px-4 py-3 rounded-xl border border-border focus:border-primary focus:ring-2 focus:ring-primary/20 outline-none transition-all text-text-dark resize-vertical"
                  placeholder="Cuéntanos en qué podemos ayudarte..."
                ></textarea>
              </div>

              <!-- Copia del mensaje -->
              <div class="flex items-start gap-3">
                <input
                  type="checkbox"
                  id="copia"
                  name="copia"
                  class="mt-1 w-4 h-4 text-primary border-border rounded focus:ring-primary/20"
                />
                <label for="copia" class="text-sm text-text-gray">
                  Enviar una copia de este mensaje a mi correo electrónico
                </label>
              </div>

              <!-- Disclaimer RGPD -->
              <div class="bg-bg-light rounded-xl border border-border p-4 text-xs text-text-gray leading-relaxed space-y-2">
                <p>De conformidad con lo dispuesto en el Reglamento General de Protección de Datos de la UE (RGPD) y en la Ley Orgánica de Protección de Datos 3/2018 de 5 de diciembre, le informamos que los datos que nos facilite forman parte de un tratamiento del que es responsable <strong>NOELIA JIMENEZ MARTIN con CIF 05293161X</strong> con la finalidad de gestionar sus datos para responder las dudas o consultas recibidas. La legitimación del tratamiento se basa en el consentimiento del interesado. No se cederán datos a terceros salvo obligación legal. Podrá ejercitar los derechos de acceso, rectificación y supresión de los datos, así como otros derechos, tal y como se explica en la información adicional. Puede consultar la información adicional y detallada sobre protección de datos clicando en la <a href="/privacidad" class="text-primary hover:underline font-medium">POLÍTICA DE PRIVACIDAD</a> o rellenando el presente formulario de contacto.</p>
                <p>Al enviar este formulario, está aceptando nuestra <a href="/privacidad" class="text-primary hover:underline font-medium">Política de Privacidad</a>.</p>
              </div>

              <!-- Privacidad -->
              <div class="flex items-start gap-3">
                <input
                  type="checkbox"
                  id="privacidad"
                  name="privacidad"
                  required
                  class="mt-1 w-4 h-4 text-primary border-border rounded focus:ring-primary/20"
                />
                <label for="privacidad" class="text-sm text-text-gray">
                  He leído y acepto la <a href="/privacidad" class="text-primary hover:underline">Política de Privacidad</a> *
                </label>
              </div>

              <!-- Honeypot anti-spam -->
              <div class="hidden" aria-hidden="true">
                <input type="text" name="website" tabindex="-1" autocomplete="off" />
              </div>

              <!-- hCaptcha -->
              <div class="h-captcha" data-sitekey="1d9426de-c448-442c-bc7e-4fe2f87c4ea2"></div>

              <!-- Submit -->
              <button
                type="submit"
                class="w-full bg-primary text-white px-6 py-3 sm:px-8 sm:py-4 rounded-xl font-semibold text-base sm:text-lg hover:bg-primary-light transition-all duration-300 shadow-lg hover:shadow-xl flex items-center justify-center gap-2"
              >
                Enviar mensaje
                <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 19l9 2-9-18-9 18 9-2zm0 0v-8" />
                </svg>
              </button>
            </form>
          </div>
        </div>

        <!-- Info de contacto -->
        <div class="space-y-6">
          <div>
            <h2 class="text-xl sm:text-2xl font-bold text-text-dark mb-6">Información de contacto</h2>
            <div class="space-y-4">
              <div class="flex items-start gap-4 p-4 bg-bg-light rounded-xl border border-border">
                <div class="w-10 h-10 bg-primary/10 rounded-lg flex items-center justify-center shrink-0">
                  <svg class="w-5 h-5 text-primary" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z" />
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z" />
                  </svg>
                </div>
                <div>
                  <p class="font-semibold text-text-dark text-sm">Dirección</p>
                  <p class="text-text-gray text-sm">c/Travesía de Alfredo Aleix, 1 (local)<br/>Carabanchel Alto, 28044 Madrid</p>
                </div>
              </div>
              <div class="flex items-start gap-4 p-4 bg-bg-light rounded-xl border border-border">
                <div class="w-10 h-10 bg-primary/10 rounded-lg flex items-center justify-center shrink-0">
                  <svg class="w-5 h-5 text-primary" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" />
                  </svg>
                </div>
                <div>
                  <p class="font-semibold text-text-dark text-sm">Teléfono</p>
                  <a href="tel:691487526" class="text-primary font-semibold hover:underline">691 487 526</a>
                </div>
              </div>
              <div class="flex items-start gap-4 p-4 bg-bg-light rounded-xl border border-border">
                <div class="w-10 h-10 bg-primary/10 rounded-lg flex items-center justify-center shrink-0">
                  <svg class="w-5 h-5 text-primary" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />
                  </svg>
                </div>
                <div>
                  <p class="font-semibold text-text-dark text-sm">Email</p>
                  <a href="mailto:fisiopilates.atlas@gmail.com" class="text-primary text-sm hover:underline">fisiopilates.atlas@gmail.com</a>
                </div>
              </div>
              <div class="flex items-start gap-4 p-4 bg-bg-light rounded-xl border border-border">
                <div class="w-10 h-10 bg-primary/10 rounded-lg flex items-center justify-center shrink-0">
                  <svg class="w-5 h-5 text-primary" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z" />
                  </svg>
                </div>
                <div>
                  <p class="font-semibold text-text-dark text-sm">Horario</p>
                  <p class="text-text-gray text-sm">Lunes a Viernes: 10:00 – 21:00 h</p>
                </div>
              </div>
            </div>
          </div>

          <!-- WhatsApp -->
          <a
            href="https://wa.me/34691487526"
            target="_blank"
            rel="noopener noreferrer"
            class="flex items-center gap-3 p-4 bg-green-50 border border-green-200 rounded-xl hover:bg-green-100 transition-colors group"
          >
            <div class="w-10 h-10 bg-green-500 rounded-lg flex items-center justify-center shrink-0">
              <svg class="w-5 h-5 text-white" fill="currentColor" viewBox="0 0 24 24">
                <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/>
              </svg>
            </div>
            <div>
              <p class="font-semibold text-green-800 text-sm">WhatsApp</p>
              <p class="text-green-600 text-sm">Escríbenos directamente</p>
            </div>
            <svg class="w-4 h-4 text-green-600 ml-auto group-hover:translate-x-1 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3" />
            </svg>
          </a>

          <!-- Transporte -->
          <div class="p-4 bg-bg-light rounded-xl border border-border">
            <h3 class="font-semibold text-text-dark text-sm mb-3">Cómo llegar</h3>
            <div class="space-y-2 text-sm text-text-gray">
              <div class="flex items-center gap-2">
                <span class="w-6 h-6 bg-primary text-white text-xs rounded-full flex items-center justify-center font-bold">M</span>
                <span>La Peseta · Carabanchel Alto</span>
              </div>
              <div class="flex items-center gap-2">
                <span class="w-6 h-6 bg-accent text-white text-xs rounded-full flex items-center justify-center font-bold">B</span>
                <span>Autobuses 35 y 47</span>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>
</Layout>

<script src="https://js.hcaptcha.com/1/api.js" async defer></script>
<script>
  const params = new URLSearchParams(window.location.search);
  if (params.get('status') === 'ok') {
    document.getElementById('form-success')?.classList.remove('hidden');
  } else if (params.get('status') === 'error') {
    document.getElementById('form-error')?.classList.remove('hidden');
  } else if (params.get('status') === 'captcha') {
    document.getElementById('form-captcha')?.classList.remove('hidden');
  }
</script>
